{{#> base}}
	{{#*inline "head"}}
		<title>{{post.markdown.title}} - Charlotte Thomas</title>
		<meta property="og:title" content="{{post.markdown.title}}"/>
		<meta property="og:article:published_time" content="{{post.metadata.published}}"/>
		<meta name="description" content="{{post.markdown.summary}}"/>
		<meta property="og:description" content="{{post.markdown.summary}}"/>
		<meta property="og:type" content="article"/>
		<link rel="stylesheet" href="{{post_css}}">
		{{#if live_reload}}<script>dependency("{{post_css}}")</script>{{/if}}
		<meta property="og:article:author" content="Charlotte Thomas"/>
		<meta property="og:article:site_name" content="analgesia.icu"/>
		<meta name="theme-color" content="#55cdfc"/>
		<link type="application/atom+xml" rel="alternate" href="{{feed}}" title="CT Writing Den's Blog">
	{{/inline}}
	{{#*inline "body"}}
		<h1>{{{post.markdown.title}}}</h1>
		<p id="published">
			{{#if post.metadata.published}}
				<time datetime="{{post.metadata.published}}">{{post.metadata.published}}</time>
			{{else}}
				Draft
			{{/if}}
			{{#if post.metadata.updated}}
				(updated <time datetime="{{post.metadata.updated}}">{{post.metadata.updated}}</time>)
			{{/if}}
		</p>
		<nav>{{{post.markdown.outline}}}</nav>
		{{{post.markdown.body}}}

		<p class="back"><a href="#">⮬ Back to top</a></p>
	{{/inline}}
{{/base}}
